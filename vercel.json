{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "redirects": [
    { "source": "/index.php", "destination": "/", "permanent": true },
    { "source": "/ru", "destination": "/", "permanent": true },
    { "source": "/ru.php", "destination": "/", "permanent": true },
    { "source": "/:page(en|tr|uz).php", "destination": "/:page", "permanent": true }
  ],
  "rewrites": [
    { "source": "/:lang(en|tr|uz)", "destination": "/api/:lang.php" },
    { "source": "/", "destination": "/api/index.php" }
  ]
}
