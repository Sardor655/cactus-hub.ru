# Clean SEO configuration
Options -Indexes -MultiViews
DirectoryIndex index.php

ErrorDocument 404 /404.php
<IfModule mod_rewrite.c>
RewriteEngine On

# Force HTTPS and non-www while preserving the path
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\.cactus\-hub\.ru$ [NC]
RewriteRule ^ https://cactus-hub.ru%{REQUEST_URI} [R=301,L]

# Root and duplicate URL normalization
RewriteCond %{THE_REQUEST} \s/+index\.php[?\s] [NC]
RewriteRule ^index\.php$ / [R=301,L]
RewriteRule ^ru/?$ / [R=301,L]

RewriteCond %{THE_REQUEST} \s/+ru\.php[?\s] [NC]
RewriteRule ^ru\.php$ / [R=301,L]

# Redirect only direct browser requests for PHP language files to clean URLs
# Do not redirect internal rewrites such as /en -> en.php, otherwise /en loops.
RewriteCond %{THE_REQUEST} \s/+en\.php[?\s] [NC]
RewriteRule ^en\.php$ /en [R=301,L]

RewriteCond %{THE_REQUEST} \s/+tr\.php[?\s] [NC]
RewriteRule ^tr\.php$ /tr [R=301,L]

RewriteCond %{THE_REQUEST} \s/+uz\.php[?\s] [NC]
RewriteRule ^uz\.php$ /uz [R=301,L]

# Remove trailing slash from clean language URLs
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} .+/$
RewriteRule ^(.+)/$ /$1 [R=301,L]

# Internal clean language URL mapping
RewriteRule ^en/?$ en.php [L,QSA]
RewriteRule ^tr/?$ tr.php [L,QSA]
RewriteRule ^uz/?$ uz.php [L,QSA]
</IfModule>

<IfModule mod_headers.c>
Header set X-Content-Type-Options "nosniff"
Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
